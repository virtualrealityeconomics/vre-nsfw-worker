# This file documents only the NON-SENSITIVE tunables.
#
# Secrets and endpoints — the database URL, the R2 credentials, ANTHROPIC_API_KEY, and the metrics
# secret — are NEVER committed. They are set as environment variables on the server that runs the
# worker (see the deploy notes). To override any tunable locally, copy it into a gitignored `.env`.

# ── NudeNet v3 gate (layer 1) — per-label thresholds, all optional ────────────
NSFW_BLOCK_GENITALIA_F=0.30
NSFW_BLOCK_GENITALIA_M=0.30
NSFW_BLOCK_ANUS=0.30
NSFW_BLOCK_BREAST_F=0.30
NSFW_BLOCK_BUTTOCKS=0.35
NSFW_BLOCK_BREAST_M=0.50
NSFW_BLOCK_BELLY=0.50
NSFW_BLOCK_GENITALIA_F_COV=0.45
NSFW_DETECT_MIN_PROB=0.2
NSFW_INFER_RES=320

# ── Vision behavior (the API key itself is a server env var, not here) ────────
NSFW_VISION_ENABLED=1
NSFW_VISION_FAIL_OPEN=

# ── Video frame sampling (NudeNet only, no Claude) ────────────────────────────
NSFW_SCENE_THRESHOLD=0.3
NSFW_FPS_FLOOR=0.5
NSFW_MIN_FRAMES=16
NSFW_MAX_FRAMES=150
NSFW_VIDEO_AGG_PCT=1.0

# ── Reliability ───────────────────────────────────────────────────────────────
NSFW_MAX_ATTEMPTS=3
NSFW_LEASE_MINUTES=10

# ── Poll cadence ──────────────────────────────────────────────────────────────
NSFW_IMAGE_POLL_SEC=2.5
NSFW_VIDEO_POLL_SEC=5
