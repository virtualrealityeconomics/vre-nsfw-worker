# ── Postgres (DIRECT connection, not the pooler) ─────────────────────────────
DIRECT_URL=

# ── R2 (Cloudflare) — public reads via media.vre.pro; creds only used to QUARANTINE blocked bytes ─
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
MEDIA_BASE=https://media.vre.pro/
QUARANTINE_PREFIX=quarantine/

# ── Claude vision (hybrid layer 2 — IMAGES only; videos stay NudeNet-only) ────
ANTHROPIC_API_KEY=
NSFW_VISION_ENABLED=1
# On a vision API error: default holds the image for review; set 1 to trust the free gate instead.
NSFW_VISION_FAIL_OPEN=
VISION_MODEL=claude-haiku-4-5-20251001
VISION_MAX_EDGE=768

# ── NudeNet v3 gate (layer 1) — per-label thresholds, all optional/tunable ────
# REJECT if any of these EXPOSED/revealing labels crosses its block threshold:
NSFW_BLOCK_GENITALIA_F=0.30
NSFW_BLOCK_GENITALIA_M=0.30
NSFW_BLOCK_ANUS=0.30
NSFW_BLOCK_BREAST_F=0.30
NSFW_BLOCK_BUTTOCKS=0.35
NSFW_BLOCK_BREAST_M=0.50
NSFW_BLOCK_BELLY=0.50
NSFW_BLOCK_GENITALIA_F_COV=0.45
# Detection floor surfaced from the model (below this, detections are dropped):
NSFW_DETECT_MIN_PROB=0.2
# Inference resolution / model path (defaults to the bundled 320n.onnx):
NSFW_INFER_RES=320
NSFW_MODEL_PATH=

# ── Video frame sampling (NudeNet only, no Claude) ────────────────────────────
NSFW_SCENE_THRESHOLD=0.3
NSFW_FPS_FLOOR=0.5
NSFW_MIN_FRAMES=16
NSFW_MAX_FRAMES=150
NSFW_VIDEO_AGG_PCT=1.0

# ── Reliability ───────────────────────────────────────────────────────────────
NSFW_MAX_ATTEMPTS=3
NSFW_LEASE_MINUTES=10

# ── Poll cadence ──────────────────────────────────────────────────────────────
NSFW_IMAGE_POLL_SEC=2.5
NSFW_VIDEO_POLL_SEC=5

# ── Metrics (secret-gated; PORT is provided by the host, else METRICS_PORT/8787) ─
METRICS_SECRET=
